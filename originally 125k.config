noelle add stats hp=4780 atk=311 def%=0.583 def%=0.583 cd=0.622; #main
noelle add stats def%=0.062*3 def=39.36 hp=507.88 hp%=0.0992 atk=33.08 atk%=0.0992 er=0.0551*9 em=39.64 cr=0.0331*6 cd=0.0662*10;

furina char lvl=90/90 cons=0 talent=9,9,9;
furina add weapon="favsword" refine=3 lvl=90/90;
