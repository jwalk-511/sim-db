furina add stats hp=4780 atk=311 hp%=0.466 hp%=0.466 cr=0.311; #main
furina add stats def=39.36 def%=0.124 hp=507.88 hp%=0.0496*2 atk=33.08 atk%=0.0992 er=0.0551*2 em=39.64 cr=0.0331*7 cd=0.0662*15;

