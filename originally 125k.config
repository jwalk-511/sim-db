# Options
options iteration=1000; 
options swap_delay=12;
energy every interval=480,720 amount=1;

# Targets
target lvl=100 resist=0.1 radius=2 pos=0,2.3 hp=100000000;

# Rotation
active noelle; # SS Stacks

for let i = 0; i < 4; i = i + 1 {
  linnea skill, attack:2;
  columbina skill;
  if .columbina.burst.ready {
    columbina burst; 
  } else { 
    columbina attack:2; 
  }
  furina skill, dash, burst;
  noelle skill, burst, attack:3, dash, attack:3;
  furina attack:2;
  noelle attack:3, dash, attack:3, dash, attack:3, dash, attack:2;  
}
