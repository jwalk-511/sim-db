```let i = 4;   // Number of rotations
active noelle;

for i; i > 0; i = i - 1 // Setup for rotation to happen [i] times
{
	linnea skill;
	columbina skill;
	if .columbina.burst.ready {
		columbina burst;
	}

	illuga skill, burst;
	noelleN3D(3); 
	noelle attack:3, swap;

	############
	############

	linnea skill;
	columbina skill;
	if .columbina.burst.ready 
	{
		columbina burst;
	}

	illuga skill, burst;
	noelleN3D(5);
	noelle attack:3, swap;

}```
